config BR2_PACKAGE_CIX_GPU_UMD
	bool "cix-gpu-umd"
	depends on BR2_aarch64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS # wayland
	# libmali.so DT_NEEDEDs libdrm.so.2, libwayland-client.so.0 and
	# libwayland-server.so.0 — without these the blob fails to dlopen.
	select BR2_PACKAGE_LIBDRM
	select BR2_PACKAGE_WAYLAND
	# Build-time GL provider wiring: libglvnd is the linkable EGL/GLES
	# dispatch (weston/gst-gl/kmscube link it); at runtime it dispatches
	# to the libEGL_cix ICD via /usr/share/glvnd/egl_vendor.d/40_cix.json.
	select BR2_PACKAGE_LIBGLVND
	select BR2_PACKAGE_LIBGLVND_DISPATCH_EGL
	select BR2_PACKAGE_LIBGLVND_DISPATCH_GLES
	# The blob ships a full-featured libgbm (modifiers2, fd_for_plane) —
	# this package is the Buildroot libgbm provider (gbm.h/gbm.pc staged).
	select BR2_PACKAGE_HAS_LIBGBM
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_FORMAT_MODIFIER_PLANE_COUNT
	select BR2_PACKAGE_LIBGBM_HAS_FEATURE_DMA_BUF
	help
	  Proprietary ARM Mali "libmali" userspace for the CIX P1
	  Immortalis-G720 (EGL / OpenGL ES / GBM / OpenCL / Vulkan) plus the
	  mali_csffw.bin GPU firmware. Runtime install under /opt/cixgpu-pro
	  with /usr/lib symlinks (Nerves has no ldconfig). Provides the
	  Buildroot libgbm virtual package and the libglvnd EGL/GLES vendor
	  ICD, so weston/gst-gl/kmscube build and run against the GPU.
	  Pair with cix-gpu-driver.

config BR2_PACKAGE_PROVIDES_LIBGBM
	default "cix-gpu-umd" if BR2_PACKAGE_CIX_GPU_UMD
