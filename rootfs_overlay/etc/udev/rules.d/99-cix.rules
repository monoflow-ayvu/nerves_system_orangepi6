# CIX P1 accelerator device permissions.
# dma-buf heaps (GPU/VPU/DSP buffer sharing) world-usable, matching the
# vendor 99-cma-device.rules.
SUBSYSTEM=="dma_heap", MODE="0666"
# NPU and GPU render nodes usable by the (single) application user.
KERNEL=="aipu", MODE="0666"
KERNEL=="mali[0-9]*", MODE="0666"
